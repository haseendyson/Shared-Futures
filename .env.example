OPENAI_API_KEY=
DEFAULT_STUDY=micron_healthcare_futures

# Feature Flags - Workflow Control
# WORKFLOW_MODE: "full" (default) or "simplified"
# - full: Complete workflow with review, rate, adapt steps
# - simplified: Streamlined workflow with inline preview
WORKFLOW_MODE=full

# Optional workflow steps (only apply in full mode)
ENABLE_REVIEW_STEP=true
ENABLE_RATE_STEP=true
ENABLE_ADAPT_STEP=true
ENABLE_COMPLETION_STEP=true
ENABLE_ECHO_INTRO=true
